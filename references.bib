@article{BIAN2022,
title = {Planning of electric vehicle fast-charging station based on POI interest point division, functional area, and multiple temporal and spatial characteristics},
journal = {Energy Reports},
volume = {8},
pages = {831-840},
year = {2022},
note = {2022 The 5th International Conference on Renewable Energy and Environment Engineering},
issn = {2352-4847},
doi = {https://doi.org/10.1016/j.egyr.2022.10.161},
url = {https://www.sciencedirect.com/science/article/pii/S2352484722020960},
author = {Haihong Bian and Chengang Zhou and Zhengyang Guo and Ximeng Wang and Ying He and Shan Peng},
keywords = {POI points of interest, Functional area, Traffic flow, Charging station planning, Signal duration, Pareto optimality, MOSAPSO algorithm},
abstract = {There are some problems with the fast-charging station of urban electric vehicles (EV), including blind construction, unreasonable planning location, and neglect of user requirements. This paper presents a planning method considering functional zoning and traffic influencing factors. Firstly, the planning area’s POI points and road network information are processed based on the geographic information software ArcGIS, and the urban functional zoning is divided. Then, two factors that affect the user’s time-consuming cost are studied, such as regional traffic congestion and signal waiting time. Secondly, according to the initial location of the user, the road network adjacency matrix, and the probability function of the user selecting the fast-charging station, the Floyd algorithm is used to calculate the time-consuming cost of the user to the fast-charging station. In order to reflect the profitability of the fast-charging station, the payback period function is also introduced. Finally, the MOSAPSO algorithm is used to solve the multi-objective function composed of the investment cost, operation, and maintenance cost, payback period, and user time-consuming cost of the fast-charging station. The optimized site selection and management layout of fast charging stations provide a certain reference for urban EV fast charging stations.}
}


@Article{Annan2024,
AUTHOR = {Annan Yang, Jiawei Zhang, Haojie Yang, Keyi Tao, Mengna Xu, Yuyu Zhao},
TITLE = {Optimization of Electric Vehicle Charging Station Layout Based on Point of Interest Data and Location Entropy Evaluation},
JOURNAL = {Journal on Big Data},
VOLUME = {6},
YEAR = {2024},
NUMBER = {1},
PAGES = {21--41},
URL = {http://www.techscience.com/jbd/v6n1/59163},
ISSN = {2579-0056},
ABSTRACT = {This study introduces an electric vehicle charging station layout optimization method utilizing Point of Interest (POI) data, addressing traditional design limitations. It details the acquisition and visualization of POI data for Yancheng’s key locations and charging stations. Employing a hybrid K-Means and Density-Based Spatial Clustering of Applications with Noise (DBSCAN) clustering algorithm, the study determines areas requiring optimization through location entropy and overlap analysis. The research shows that the integrated clustering approach can efficiently guide the fair distribution of charging stations, enhancing service quality and supporting the sustainable growth of the electric vehicle sector.},
DOI = {10.32604/jbd.2024.057612}
}




@Article{Zhang2025,
AUTHOR = {Zhang, Qian and Si, Guiwu and Li, Hongyi},
TITLE = {Optimization of Electric Vehicle Charging Station Location Distribution Based on Activity–Travel Patterns},
JOURNAL = {ISPRS International Journal of Geo-Information},
VOLUME = {14},
YEAR = {2025},
NUMBER = {10},
ARTICLE-NUMBER = {373},
URL = {https://www.mdpi.com/2220-9964/14/10/373},
ISSN = {2220-9964},
ABSTRACT = {With the rapid expansion of the electric vehicle (EV) market, optimizing the distribution of charging stations has attracted increasing attention. Unlike internal combustion engine vehicles, EVs are typically charged at the end of a trip rather than during transit. Therefore, analyzing EV users’ charging preferences based on their activity–travel patterns is essential. This study seeks to improve the operational efficiency and accessibility of EV charging stations in Lanzhou City by optimizing their spatial distribution. To achieve this, a novel multi-objective optimization model integrating NSGA-III and TOPSIS is proposed. The methodology consists of two key steps. First, the NSGA-III algorithm is applied to optimize three objective functions: minimizing construction costs, maximizing user satisfaction, and maximizing user convenience, thereby identifying charging station locations that address diverse needs. Second, the TOPSIS method is employed to rank and evaluate various location solutions, ultimately determining the final sitting strategy. The results show that the 232 locations obtained by the optimization model are reasonably distributed, with good operational efficiency and convenience. Most of them are distributed in urban centers and commercial areas, which is consistent with the usage scenarios of EV users. In addition, this study demonstrates the superiority in determining the distribution of charging station locations of the proposed method. In summary, this study determined the optimal distribution of 232 EV charging stations in Lanzhou City using multi-objective optimization and ranking methods. The results are of great significance for improving the operational efficiency and convenience of charging station location optimization and offer valuable insights for other cities in northwestern China in planning their charging infrastructure.},
DOI = {10.3390/ijgi14100373}
}



