@article{WANG_DENG_YAN_LI_2025, title={Optimisation of Electric Vehicle Charging Stations Planning Based on Macro and Micro Perspectives}, volume={37}, url={https://traffic2.fpz.hr/index.php/PROMTT/article/view/770}, DOI={10.7307/ptt.v37i4.770}, abstractNote={&amp;lt;p&amp;gt;The growing ownership of electric vehicles in urban areas leads to increasing demand for public charging spaces. With existing charging facilities failing to match the constantly increasing demand for charging, it is necessary to plan for new charging infrastructure. A two-stage approach is proposed for public charging infrastructure planning from both macro and micro perspectives. Firstly, a linear regression model with an exponential elasticity function is used to estimate charging demand, considering comprehensive charging demand factors. Secondly, effective served charging demand (ESCD) is proposed to accurately calculate the charging demand of effective service areas, considering the distance impact factor and competition among neighbouring charging stations. A capacitated maximal service location model (CMSLM) is proposed to optimise the spatial layout of public charging stations by maximizing their ESCD while considering investment budget and charging station capacity limits. CMSLM is solved using sparrow search algorithm from both macro and micro perspectives. The proposed approach is applied to Guangzhou, China, as a case study. Results show that when the investment budget is increased to 5 million CNY, the ESCD of all districts under the macro and micro optimisation perspectives increases by an average of 41.0% and 34.1%, respectively. Optimised charging stations can remedy the spatial imbalance between charging demand and existing charging station distribution, laying the foundation for further construction implementation.&amp;lt;/p&amp;gt;}, number={4}, journal={Promet - Traffic&amp;Transportation}, author={WANG, Qiuxuan and DENG, Kunxiang and YAN, Jiangnan and LI, Jun}, year={2025}, month={Jul.}, pages={963–979} }

@inbook{Zechao2024,
author = {Zechao Ma  and Xiaoming Liu  and Hanqing Xia  and Weiqiang Wang },
title = {Research on the Planning of Electric Vehicle Charging Stations Based on Multi-View Graph Convolutional Networks},
booktitle = {CICTP 2024},
chapter = {},
pages = {2895-2905},
doi = {10.1061/9780784485484.273},
URL = {https://ascelibrary.org/doi/abs/10.1061/9780784485484.273},
eprint = {https://ascelibrary.org/doi/pdf/10.1061/9780784485484.273},
    abstract = { In 2020, electric vehicle charging infrastructure was included in “new infrastructure,” and its incremental growth has continued rapidly. However, there is still significant room for improvement in public charging pile density. Public charging infrastructure needs to be strategically located and expanded within urban spaces based on the specific needs and charging behaviors of different types of users. This study first utilizes heterogeneous data from multiple sources to analyze the behavioral characteristics of electric vehicle users and the impact of urban spatial attributes on charging demand. Subsequently, a modularity-optimized community detection algorithm is employed to partition urban spaces. Finally, a multi-view graph convolutional neural network, integrated with the XGBoost algorithm, is established to predict charging demand in specific areas within these communities. The model presented in this paper outperforms traditional graph neural networks in terms of regression and classification performance. }
}

